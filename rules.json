[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "redirect",
      "redirect": { "transform": { "scheme": "https" } }
    },
    "condition": {
      "urlFilter": "http://*",
      "resourceTypes": ["main_frame", "sub_frame"],
      "excludedDomains": ["127.0.0.1", "localhost"]
    }
  },
  {
    "id": 2,
    "priority": 1,
    "action": { "type": "block" },
    "condition": {
      "urlFilter": "doubleclick.net",
      "resourceTypes": ["script", "image", "xmlhttprequest"]
    }
  },
  {
    "id": 3,
    "priority": 1,
    "action": { "type": "block" },
    "condition": {
      "urlFilter": "facebook.net",
      "resourceTypes": ["script", "image", "xmlhttprequest"]
    }
  },
  {
    "id": 4,
    "priority": 1,
    "action": { "type": "block" },
    "condition": {
      "urlFilter": "googletagmanager.com",
      "resourceTypes": ["script", "image", "xmlhttprequest"]
    }
  }
]

